    "prepackage:vsix": "npm run build",
    "package:vsix": "npx @vscode/vsce package --allow-star-activation --allow-missing-repository --baseContentUrl https://drylake.xupracorp.com/marketplace/extension/ --baseImagesUrl https://drylake.xupracorp.com/marketplace/extension/",
    "package:local": "node scripts/package-local-extension.mjs",
    "install:vsix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-vsix.ps1",
    "reinstall:vsix": "npm run package:vsix && npm run install:vsix",
    "uninstall:vscode": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-vscode-extension.ps1"
  },
