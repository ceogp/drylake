        {
          "command": "xupra.signOut",
          "when": "view == xupra.projects && xupra.connected",
          "group": "navigation"
        },
        {
          "command": "xupra.resetWorkspaceState",
          "when": "view == xupra.help",
          "group": "navigation"
        },
        {
          "command": "xupra.openSettings",
          "when": "view == xupra.help",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "xupra.optimizeFile",
          "when": "resourceFilename == AGENTS.md || resourceFilename == CLAUDE.md || resourceFilename == GEMINI.md || resourceFilename == WARP.md || resourceFilename == .rules || resourceFilename == .roorules || resourceFilename == .clinerules || resourceExtname == .toml && resourcePath =~ /\\.codex[\\\\/]agents[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.claude[\\\\/]agents[\\\\/]/ || resourceExtname == .mdc && resourcePath =~ /\\.cursor[\\\\/]rules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.windsurf[\\\\/]rules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.clinerules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.roo[\\\\/]rules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.github[\\\\/](copilot-instructions\\.md|instructions[\\\\/])/ || resourceExtname == .md && resourcePath =~ /\\.junie[\\\\/]guidelines\\.md/",
          "group": "navigation@9"
        }
      ],
      "explorer/context": [
        {
          "command": "xupra.optimizeFile",
          "when": "resourceFilename == AGENTS.md || resourceFilename == CLAUDE.md || resourceFilename == GEMINI.md || resourceFilename == WARP.md || resourceFilename == .rules || resourceFilename == .roorules || resourceFilename == .clinerules || resourceExtname == .toml && resourcePath =~ /\\.codex[\\\\/]agents[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.claude[\\\\/]agents[\\\\/]/ || resourceExtname == .mdc && resourcePath =~ /\\.cursor[\\\\/]rules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.windsurf[\\\\/]rules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.clinerules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.roo[\\\\/]rules[\\\\/]/ || resourceExtname == .md && resourcePath =~ /\\.github[\\\\/](copilot-instructions\\.md|instructions[\\\\/])/ || resourceExtname == .md && resourcePath =~ /\\.junie[\\\\/]guidelines\\.md/",
          "group": "7_modification"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
