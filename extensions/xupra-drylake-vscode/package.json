  "contributes": {
    "configuration": {
      "title": "DryLake",
      "properties": {
        "drylake.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional API base URL override for DryLake AI planning. Leave empty to use the default DryLake backend."
        },
        "drylake.aiProvider": {
          "type": "string",
          "enum": [
            "xupra-pro-ai",
            "databricks-api",
            "claude-api",
            "openai-api",
            "hermes-agent"
          ],
          "enumItemLabels": [
            "DryLake AI Planning",
            "Databricks API",
            "Claude API",
            "OpenAI API",
            "Hermes Agent CLI"
          ],
          "default": "xupra-pro-ai",
          "description": "Planning provider used to create and revise DryLake build plans. Direct API providers prompt once, test the connection, and store accepted keys in VS Code SecretStorage; DryLake AI remains the default."
        },
        "drylake.directApi.timeoutSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 15,
          "maximum": 900,
          "description": "Maximum time DryLake waits for direct API planning providers."
        },
        "drylake.openai.apiKeyEnvVar": {
          "type": "string",
          "default": "OPENAI_API_KEY",
          "description": "Optional environment variable fallback for the OpenAI API key. Most users can enter the key when DryLake prompts and stores it in VS Code SecretStorage."
        },
        "drylake.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible base URL used by the OpenAI API planning provider."
        },
        "drylake.openai.model": {
          "type": "string",
          "default": "gpt-5",
          "description": "OpenAI model used for DryLake planning."
        },
        "drylake.openai.maxOutputTokens": {
          "type": "number",
          "default": 8000,
          "minimum": 512,
          "maximum": 32000,
          "description": "Maximum output tokens requested from the OpenAI API planning provider."
        },
        "drylake.claude.apiKeyEnvVar": {
          "type": "string",
          "default": "ANTHROPIC_API_KEY",
          "description": "Optional environment variable fallback for the Anthropic API key. Most users can enter the key when DryLake prompts and stores it in VS Code SecretStorage."
        },
        "drylake.claude.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com/v1",
          "description": "Anthropic API base URL used by the Claude planning provider."
        },
        "drylake.claude.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Claude model used for DryLake planning."
        },
        "drylake.claude.maxOutputTokens": {
          "type": "number",
          "default": 8000,
          "minimum": 512,
          "maximum": 32000,
          "description": "Maximum output tokens requested from the Claude API planning provider."
        },
        "drylake.databricks.tokenEnvVar": {
          "type": "string",
          "default": "DATABRICKS_TOKEN",
          "description": "Optional environment variable fallback for the Databricks token. Most users can enter the token when DryLake prompts and stores it in VS Code SecretStorage."
        },
        "drylake.databricks.workspaceUrl": {
          "type": "string",
          "default": "",
          "description": "Databricks workspace URL, for example https://example.cloud.databricks.com."
        },
        "drylake.databricks.endpointName": {
          "type": "string",
          "default": "",
          "description": "Databricks Model Serving endpoint name used for DryLake planning."
        },
        "drylake.databricks.maxOutputTokens": {
          "type": "number",
          "default": 8000,
          "minimum": 512,
          "maximum": 32000,
          "description": "Maximum output tokens requested from the Databricks planning endpoint."
        },
        "drylake.agents.claude-code.command": {
          "type": "string",
          "default": "claude",
          "description": "Command or full executable path DryLake uses to launch Claude Code handoffs."
        },
        "drylake.agents.codex.command": {
          "type": "string",
          "default": "codex",
          "description": "Command or full executable path DryLake uses to launch OpenAI Codex handoffs."
        },
        "drylake.agents.gemini.command": {
          "type": "string",
          "default": "gemini",
          "description": "Command or full executable path DryLake uses to launch Gemini CLI handoffs."
        },
        "drylake.agents.hermes.command": {
          "type": "string",
          "default": "hermes",
          "description": "Command or full executable path DryLake uses to launch Hermes Agent handoffs."
        },
        "drylake.agents.blackbox.command": {
          "type": "string",
          "default": "blackbox",
          "description": "Command or full executable path DryLake uses to launch Blackbox CLI handoffs."
        },
        "drylake.agents.goose.command": {
          "type": "string",
          "default": "goose",
          "description": "Command or full executable path DryLake uses to launch Goose CLI handoffs."
        },
        "drylake.agents.opencode.command": {
          "type": "string",
          "default": "opencode",
          "description": "Command or full executable path DryLake uses to launch OpenCode handoffs."
        },
        "drylake.agents.qwen.command": {
          "type": "string",
          "default": "qwen",
          "description": "Command or full executable path DryLake uses to launch Qwen Code handoffs."
        },
        "drylake.agents.continue.command": {
          "type": "string",
          "default": "cn",
          "description": "Command or full executable path DryLake uses to launch Continue CLI handoffs."
        },
        "drylake.agents.cline.command": {
          "type": "string",
          "default": "cline",
          "description": "Command or full executable path DryLake uses to launch Cline CLI handoffs."
        },
        "drylake.agents.aider.command": {
          "type": "string",
          "default": "aider",
          "description": "Command or full executable path DryLake uses to launch Aider handoffs."
        },
        "drylake.agents.kilo.command": {
          "type": "string",
          "default": "kilo",
          "description": "Command or full executable path DryLake uses to launch Kilo Code handoffs."
        },
        "drylake.agents.auggie.command": {
          "type": "string",
          "default": "auggie",
          "description": "Command or full executable path DryLake uses to launch Auggie CLI handoffs."
        },
        "drylake.hermes.planningTimeoutSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 15,
          "maximum": 900,
          "description": "Maximum time DryLake waits for Hermes Agent CLI planning requests."
        },
        "drylake.hermes.maxOutputBytes": {
          "type": "number",
          "default": 1500000,
          "minimum": 100000,
          "maximum": 10000000,
          "description": "Maximum Hermes Agent CLI planning output DryLake will read before failing the request."
        },
        "drylake.agents.cursor.command": {
          "type": "string",
          "default": "cursor-agent",
          "description": "Command or full executable path DryLake uses to launch Cursor CLI handoffs."
        },
        "xupra.baseUrl": {
          "type": "string",
          "default": "https://drylake.xupracorp.com",
          "description": "Base URL for the Xupra DryLake backend."
        },
        "xupra.autoScanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically import supported files when a workspace opens."
        },
        "xupra.includeGlobalAgentFiles": {
          "type": "boolean",
          "default": true,
          "description": "Include default global agent folders such as ~/.codex, ~/.claude, and ~/.cursor when scanning."
        },
        "xupra.additionalScanPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional file patterns for unusual agent locations."
        },
        "xupra.scan.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.env",
            "**/.env.*",
            "**/secrets/**"
          ],
          "description": "Additional glob patterns excluded from the workspace scan. Built-in excludes for node_modules, .git, dist, build, etc. always apply."
        },
        "xupra.openDashboardAfterConnect": {
          "type": "boolean",
          "default": true,
          "description": "Open the Xupra dashboard in your browser after a successful connection."
        },
        "xupra.defaultTargetPlatform": {
          "type": "string",
          "enum": [
            "codex",
            "claude_code",
            "claude_agents",
            "cursor",
            "copilot",
            "gemini",
            "vscode",
            "generic"
          ],
          "enumItemLabels": [
            "OpenAI Codex",
            "Claude Code",
            "Claude Agents",
            "Cursor",
            "GitHub Copilot Chat",
            "Gemini CLI",
            "VS Code",
            "Generic Markdown"
          ],
          "default": "vscode",
          "description": "Default format for exported handoff prompts and agent configuration files."
        },
        "xupra.pullGeneratedFilesAfterExport": {
          "type": "boolean",
          "default": false,
          "description": "Pull generated files into the workspace after export preview."
        },
        "xupra.confirmBeforeWriteback": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before writing generated files into the current workspace."
        },
        "xupra.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Logging verbosity for the extension."
        }
      }
    },
