{
  "name": "xupra-drylake-vscode",
  "displayName": "Xupra DryLake",
  "description": "Transfer agent packages between Codex, Claude Code, Cursor, and Claude Agents from VS Code and Cursor.",
  "version": "0.0.1",
  "private": true,
  "publisher": "xupra",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:xupra.projects",
    "onView:xupra.jobs",
    "onView:xupra.help",
    "onCommand:xupra.connect",
    "onCommand:xupra.scanWorkspace",
    "onCommand:xupra.refreshProjects",
    "onCommand:xupra.importWorkspace",
    "onCommand:xupra.checkCompatibility",
    "onCommand:xupra.exportPreview",
    "onCommand:xupra.deploy",
    "onCommand:xupra.pullPackage",
    "onCommand:xupra.openWebApp",
    "onCommand:xupra.openSettings",
    "onCommand:xupra.openAccountSettings",
    "onCommand:xupra.openBilling",
    "onCommand:xupra.openInstallGuide",
    "onCommand:xupra.openGetStarted"
  ],
  "contributes": {
    "configuration": {
      "title": "Xupra DryLake",
      "properties": {
        "xupra.baseUrl": {
          "type": "string",
          "default": "http://localhost:3002",
          "description": "Base URL for the Xupra DryLake backend."
        },
        "xupra.devEmail": {
          "type": "string",
          "default": "owner@xupra.local",
          "description": "Development email used before real auth is connected."
        },
        "xupra.devDisplayName": {
          "type": "string",
          "default": "Xupra Owner",
          "description": "Development display name used before real auth is connected."
        },
        "xupra.autoScanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan the current workspace on open."
        },
        "xupra.additionalScanPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to scan when your agent files live outside the default directories."
        },
        "xupra.openDashboardAfterConnect": {
          "type": "boolean",
          "default": true,
          "description": "Open the Xupra dashboard in your browser after a successful connection."
        },
        "xupra.defaultTargetPlatform": {
          "type": "string",
          "enum": [
            "codex",
            "claude_code",
            "claude_agents",
            "cursor"
          ],
          "default": "claude_code",
          "description": "Default target platform for compatibility and export actions."
        },
        "xupra.pullGeneratedFilesAfterExport": {
          "type": "boolean",
          "default": false,
          "description": "Pull generated files into the workspace after export preview."
        },
        "xupra.confirmBeforeWriteback": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before writing generated files into the current workspace."
        },
        "xupra.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Logging verbosity for the extension."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xupra",
          "title": "Xupra DryLake",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "xupra": [
        {
          "id": "xupra.projects",
          "name": "Workspace"
        },
        {
          "id": "xupra.jobs",
          "name": "Jobs"
        },
        {
          "id": "xupra.help",
          "name": "Help"
        }
      ]
    },
    "commands": [
      {
        "command": "xupra.connect",
        "title": "Xupra DryLake: Connect"
      },
      {
        "command": "xupra.openWebApp",
        "title": "Xupra DryLake: Open Web App"
      },
      {
        "command": "xupra.refreshProjects",
        "title": "Xupra DryLake: Refresh Projects"
      },
      {
        "command": "xupra.scanWorkspace",
        "title": "Xupra DryLake: Scan Workspace"
      },
      {
        "command": "xupra.selectProject",
        "title": "Xupra DryLake: Select Project"
      },
      {
        "command": "xupra.selectPackage",
        "title": "Xupra DryLake: Select Package"
      },
      {
        "command": "xupra.selectVersion",
        "title": "Xupra DryLake: Select Version"
      },
      {
        "command": "xupra.scanWorkspace",
        "title": "Xupra DryLake: Scan Workspace"
      },
      {
        "command": "xupra.importWorkspace",
        "title": "Xupra DryLake: Import Workspace"
      },
      {
        "command": "xupra.checkCompatibility",
        "title": "Xupra DryLake: Check Compatibility"
      },
      {
        "command": "xupra.exportPreview",
        "title": "Xupra DryLake: Export Preview"
      },
      {
        "command": "xupra.pullPackage",
        "title": "Xupra DryLake: Pull Package Files"
      },
      {
        "command": "xupra.deploy",
        "title": "Xupra DryLake: Deploy"
      },
      {
        "command": "xupra.showRecentJobs",
        "title": "Xupra DryLake: Show Recent Jobs"
      },
      {
        "command": "xupra.openSettings",
        "title": "Xupra DryLake: Open Extension Settings"
      },
      {
        "command": "xupra.openAccountSettings",
        "title": "Xupra DryLake: Open Account Settings"
      },
      {
        "command": "xupra.openBilling",
        "title": "Xupra DryLake: Open Billing"
      },
      {
        "command": "xupra.openInstallGuide",
        "title": "Xupra DryLake: Open Install Guide"
      },
      {
        "command": "xupra.openGetStarted",
        "title": "Xupra DryLake: Open Get Started Page"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xupra.refreshProjects",
          "when": "view == xupra.projects",
          "group": "navigation"
        },
        {
          "command": "xupra.importWorkspace",
          "when": "view == xupra.projects",
          "group": "navigation"
        },
        {
          "command": "xupra.scanWorkspace",
          "when": "view == xupra.projects",
          "group": "navigation"
        },
        {
          "command": "xupra.deploy",
          "when": "view == xupra.jobs",
          "group": "navigation"
        },
        {
          "command": "xupra.openSettings",
          "when": "view == xupra.help",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "xupra.selectProject",
          "when": "view == xupra.projects && viewItem == xupra.project",
          "group": "inline"
        },
        {
          "command": "xupra.selectPackage",
          "when": "view == xupra.projects && viewItem == xupra.package",
          "group": "inline"
        },
        {
          "command": "xupra.selectVersion",
          "when": "view == xupra.projects && viewItem == xupra.version",
          "group": "inline"
        },
        {
          "command": "xupra.deploy",
          "when": "view == xupra.projects && viewItem == xupra.version",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "check:cursor": "node scripts/check-cursor-compatibility.mjs",
    "prepackage": "npm run build",
    "package:vsix": "npx @vscode/vsce package --allow-star-activation"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}
