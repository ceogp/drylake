generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                   @id @default(cuid())
  email                 String                   @unique
  authProvider          String                   @default("dev")
  authSubject           String?
  status                String                   @default("active")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  profile               Profile?
  memberships           OrganizationMembership[]
  createdProjects       Project[]                @relation("ProjectCreator")
  createdPackages       AgentPackage[]           @relation("PackageCreator")
  createdVersions       PackageVersion[]         @relation("VersionCreator")
  createdCredentials    Credential[]             @relation("CredentialCreator")
  createdTargets        DeploymentTarget[]       @relation("TargetCreator")
  transformJobs         TransformJob[]           @relation("TransformJobCreator")
  deploymentJobs        DeploymentJob[]          @relation("DeploymentJobCreator")
  auditEvents           AuditEvent[]             @relation("AuditActor")
  credentialAccessLogs  CredentialAccessLog[]    @relation("CredentialAccessActor")
  extensionAuthRequests ExtensionAuthRequest[]
  extensionUsageEvents  ExtensionUsageEvent[]    @relation("ExtensionUsageActor")
  createdAgentTokens    AgentToken[]             @relation("AgentTokenCreator")
  guardScans            GuardScan[]              @relation("GuardScanActor")
  guardArtifacts        GuardArtifact[]          @relation("GuardArtifactActor")
  guardWatchEvents      GuardWatchEvent[]        @relation("GuardWatchEventActor")
  guardBaselines        GuardBaseline[]          @relation("GuardBaselineCreator")
  cloudAnalysisJobs     CloudAnalysisJob[]       @relation("CloudAnalysisJobActor")
  appSessions           AppSession[]
  authEvents            AuthEvent[]              @relation("AuthEventActor")
  productAccounts       ProductAccount[]

  @@unique([authProvider, authSubject])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  avatarUrl   String?
  jobTitle    String?
  phoneNumber String?
  country     String?
  addressLine1 String?
  addressLine2 String?
  city        String?
  region      String?
  postalCode  String?
  signupPlanIntent String?
  onboardingCompletedAt DateTime?
  timezone    String   @default("UTC")
  locale      String   @default("en-US")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id                    String                   @id @default(cuid())
  name                  String
  slug                  String                   @unique
  tier                  String                   @default("free")
  status                String                   @default("active")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  memberships           OrganizationMembership[]
  projects              Project[]
  credentials           Credential[]
  integrations          Integration[]
  subscriptions         Subscription[]
  transformJobs         TransformJob[]
  deploymentJobs        DeploymentJob[]
  auditEvents           AuditEvent[]
  extensionAuthRequests ExtensionAuthRequest[]
  extensionUsageEvents  ExtensionUsageEvent[]
  agentTokens           AgentToken[]
  agentPreflightRuns    AgentPreflightRun[]
  guardScans            GuardScan[]
  guardArtifacts        GuardArtifact[]
  guardWatchEvents      GuardWatchEvent[]
  guardBaselines        GuardBaseline[]
  teamPolicies          TeamPolicy[]
  cloudAnalysisJobs     CloudAnalysisJob[]
  appSessions           AppSession[]
  authEvents            AuthEvent[]
  invitations           OrganizationInvitation[]
  productAccounts       ProductAccount[]
  trustCompanies        TrustCompany[]
  trustRegistryCases    TrustRegistryCase[]
  trustBillingInvoices  TrustBillingInvoice[]
  trustBillingSubscriptions TrustBillingSubscription[]
  trustSurveyInvites    TrustSurveyInvite[]
}

model ProductAccount {
  id                    String        @id @default(cuid())
  userId                String
  organizationId        String?
  productKey            String        @default("drylake")
  status                String        @default("active")
  planIntent            String?
  onboardingCompletedAt DateTime?
  metadataJson          Json?
  firstSeenAt           DateTime      @default(now())
  lastSeenAt            DateTime      @default(now())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([userId, productKey])
  @@index([productKey, createdAt])
  @@index([organizationId, productKey])
  @@index([planIntent])
  @@index([status])
}

model TrustCompany {
  id                      String                    @id @default(cuid())
  organizationId          String?
  legalName               String
  displayName             String
  slug                    String                    @unique
  country                 String
  sizeClass               String                    @default("small")
  websiteUrl              String
  primaryProductUrl       String?
  businessContactEmail    String?
  securityContactEmail    String?
  privacyContactEmail     String?
  githubOrganizationUrl   String?
  packageRegistryLinksJson Json?
  description             String?
  categoriesJson          Json?
  japanMarketInterestJson Json?
  verifiedDomain          String?
  status                  String                    @default("draft")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  organization            Organization?             @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  domains                 TrustCompanyDomain[]
  contacts                TrustCompanyContact[]
  products                TrustProduct[]
  registryCases           TrustRegistryCase[]
  registryAssets          TrustRegistryAsset[]
  scanOrders              TrustScanOrder[]
  scanRuns                TrustScanRun[]
  certificates            TrustCertificate[]
  billingInvoices         TrustBillingInvoice[]
  billingSubscriptions    TrustBillingSubscription[]
  surveyInvites           TrustSurveyInvite[]

  @@index([organizationId])
  @@index([status])
  @@index([country])
  @@index([verifiedDomain])
}

model TrustCompanyDomain {
  id                String       @id @default(cuid())
  companyId         String
  domain            String
  verificationToken String
  txtRecordName     String
  txtRecordValue    String
  status            String       @default("pending")
  verifiedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  company           TrustCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, domain])
  @@index([domain])
  @@index([status])
}

model TrustCompanyContact {
  id        String       @id @default(cuid())
  companyId String
  kind      String
  email     String
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  company   TrustCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, kind, email])
  @@index([email])
}

model TrustRegistryStandard {
  id                   String              @id @default(cuid())
  slug                 String
  version              String
  title                String
  status               String              @default("draft")
  summary              String?
  ecosystem            String              @default("agent_to_agent")
  controlsJson         Json
  credentialSchemaJson Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  registryCases        TrustRegistryCase[]

  @@unique([slug, version])
  @@index([status])
  @@index([ecosystem])
}

model TrustRegistryCase {
  id                    String                @id @default(cuid())
  caseNumber            String                @unique
  companyId             String?
  organizationId        String?
  standardId            String?
  status                String                @default("discovered")
  outreachStatus        String                @default("not_contacted")
  interestStatus        String                @default("unknown")
  paymentStatus         String                @default("not_invoiced")
  reviewStatus          String                @default("not_started")
  companyName           String
  websiteUrl            String?
  primaryContactEmail   String?
  discoveredSource      String?
  discoveredUrl         String?
  rippleEcosystemScope  String?
  notes                 String?
  publicListingEnabled  Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  company               TrustCompany?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  organization          Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  standard              TrustRegistryStandard? @relation(fields: [standardId], references: [id], onDelete: SetNull)
  assets                TrustRegistryAsset[]
  events                TrustRegistryEvent[]
  testRuns              TrustRegistryTestRun[]
  scanOrders            TrustScanOrder[]
  certificates          TrustCertificate[]
  billingInvoices       TrustBillingInvoice[]
  surveyInvites         TrustSurveyInvite[]

  @@index([companyId])
  @@index([organizationId])
  @@index([standardId])
  @@index([status, updatedAt])
  @@index([outreachStatus])
  @@index([paymentStatus])
  @@index([reviewStatus])
  @@index([publicListingEnabled])
}

model TrustRegistryAsset {
  id               String                 @id @default(cuid())
  registryCaseId   String
  companyId        String?
  productId        String?
  assetType        String
  name             String
  status           String                 @default("discovered")
  sourceUrl        String?
  packageName      String?
  repositoryUrl    String?
  endpointUrl      String?
  agentCardUrl     String?
  did              String?
  protocol         String?
  description      String?
  metadataJson     Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  registryCase     TrustRegistryCase      @relation(fields: [registryCaseId], references: [id], onDelete: Cascade)
  company          TrustCompany?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  product          TrustProduct?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  testRuns         TrustRegistryTestRun[]
  certificates     TrustCertificate[]

  @@index([registryCaseId])
  @@index([companyId])
  @@index([productId])
  @@index([assetType])
  @@index([status])
  @@index([did])
}

model TrustRegistryTestRun {
  id               String              @id @default(cuid())
  registryCaseId   String
  registryAssetId  String?
  provider         String
  testType         String
  status           String              @default("queued")
  externalJobId    String?
  recommendation   String?
  riskClass        String?
  kyaLevel         String?
  criticalFindings Int                 @default(0)
  highFindings     Int                 @default(0)
  mediumFindings   Int                 @default(0)
  lowFindings      Int                 @default(0)
  summaryJson      Json?
  evidenceJson     Json?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  registryCase     TrustRegistryCase   @relation(fields: [registryCaseId], references: [id], onDelete: Cascade)
  registryAsset    TrustRegistryAsset? @relation(fields: [registryAssetId], references: [id], onDelete: SetNull)

  @@index([registryCaseId])
  @@index([registryAssetId])
  @@index([provider])
  @@index([testType])
  @@index([status])
  @@index([riskClass])
  @@index([kyaLevel])
}

model TrustRegistryEvent {
  id             String            @id @default(cuid())
  registryCaseId String
  eventType      String
  title          String
  detail         String?
  actor          String?
  metadataJson   Json?
  createdAt      DateTime          @default(now())
  registryCase   TrustRegistryCase @relation(fields: [registryCaseId], references: [id], onDelete: Cascade)

  @@index([registryCaseId, createdAt])
  @@index([eventType])
}

model TrustProduct {
  id             String                  @id @default(cuid())
  companyId      String
  name           String
  slug           String
  description    String?
  categoriesJson Json?
  productUrl     String?
  repositoryUrl  String?
  packageName    String?
  status         String                  @default("draft")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  company        TrustCompany            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mcpServer      TrustMcpServer?
  kyaQuestionnaires TrustKyaQuestionnaire[]
  scanOrders     TrustScanOrder[]
  scanRuns       TrustScanRun[]
  certificates   TrustCertificate[]
  billingSubscriptions TrustBillingSubscription[]
  surveyInvites  TrustSurveyInvite[]
  registryAssets TrustRegistryAsset[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([status])
}

model TrustMcpServer {
  id                      String       @id @default(cuid())
  productId               String       @unique
  companyId               String
  transport               String
  packageType             String?
  packageIdentifier       String?
  repositoryUrl           String?
  officialRegistryUrl     String?
  remoteEndpoint          String?
  authMethod              String?
  requiredEnvVarsJson     Json?
  requiresSecrets         Boolean      @default(false)
  filesystemAccess        String       @default("none")
  shellExecution          Boolean      @default(false)
  networkAccess           Boolean      @default(false)
  databaseWriteAccess     Boolean      @default(false)
  emailMessageAccess      Boolean      @default(false)
  walletPaymentAccess     Boolean      @default(false)
  productionWriteAccess   Boolean      @default(false)
  declaredToolsJson       Json?
  discoveredToolsJson     Json?
  declaredResourcesJson   Json?
  discoveredResourcesJson Json?
  declaredPromptsJson     Json?
  discoveredPromptsJson   Json?
  declaredPermissionsJson Json?
  observedPermissionsJson Json?
  riskClass               String       @default("MCP-R0")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  product                 TrustProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([riskClass])
  @@index([transport])
}

model TrustKyaQuestionnaire {
  id          String        @id @default(cuid())
  companyId   String
  productId   String?
  answersJson Json
  evidenceJson Json?
  score       Int           @default(0)
  kyaLevel    String        @default("KYA-L0")
  submittedAt DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  product     TrustProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([productId])
  @@index([kyaLevel])
}

model TrustScanOrder {
  id               String         @id @default(cuid())
  companyId        String
  productId        String?
  registryCaseId   String?
  billingInvoiceId String?
  state            String         @default("draft")
  scanType         String         @default("basic_safety_scan")
  requestedByEmail String?
  submittedByUserId String?
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  company          TrustCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product          TrustProduct?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  registryCase     TrustRegistryCase? @relation(fields: [registryCaseId], references: [id], onDelete: SetNull)
  scanRuns         TrustScanRun[]
  reviewDecisions  TrustReviewDecision[]

  @@index([companyId, state])
  @@index([productId])
  @@index([registryCaseId])
  @@index([billingInvoiceId])
}

model TrustScanRun {
  id               String             @id @default(cuid())
  scanOrderId      String
  companyId        String
  productId        String?
  status           String             @default("queued")
  recommendation   String?
  riskClass        String?
  kyaLevel         String?
  criticalFindings Int                @default(0)
  highFindings     Int                @default(0)
  mediumFindings   Int                @default(0)
  lowFindings      Int                @default(0)
  summaryJson      Json?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  scanOrder        TrustScanOrder     @relation(fields: [scanOrderId], references: [id], onDelete: Cascade)
  company          TrustCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product          TrustProduct?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  findings         TrustScanFinding[]
  reviewDecisions  TrustReviewDecision[]
  certificates     TrustCertificate[]

  @@index([scanOrderId])
  @@index([companyId, createdAt])
  @@index([productId])
  @@index([status])
  @@index([riskClass])
  @@index([kyaLevel])
}

model TrustScanFinding {
  id               String       @id @default(cuid())
  scanRunId        String
  severity         String
  module           String
  code             String
  title            String
  detail           String
  recommendation   String?
  publicDisclosure Boolean      @default(false)
  createdAt        DateTime     @default(now())
  scanRun          TrustScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@index([severity])
  @@index([module])
}

model TrustReviewDecision {
  id             String          @id @default(cuid())
  scanOrderId    String
  scanRunId      String?
  reviewerUserId String?
  decision       String
  reason         String?
  stateAfter     String
  createdAt      DateTime        @default(now())
  scanOrder      TrustScanOrder  @relation(fields: [scanOrderId], references: [id], onDelete: Cascade)
  scanRun        TrustScanRun?   @relation(fields: [scanRunId], references: [id], onDelete: SetNull)

  @@index([scanOrderId, createdAt])
  @@index([scanRunId])
  @@index([decision])
}

model TrustCertificate {
  id                    String                         @id @default(cuid())
  certificateId         String                         @unique
  companyId             String
  productId             String?
  registryCaseId        String?
  registryAssetId       String?
  scanRunId             String?
  status                String                         @default("active")
  scopeJson             Json
  standardVersion       String                         @default("mcp-kya-basic-v0.1")
  riskClass             String?
  kyaLevel              String?
  issuedAt              DateTime
  expiresAt             DateTime
  lastCheckedAt         DateTime?
  evidenceHash          String
  canonicalJson         Json
  signedCertificateJson Json
  signature             String
  signatureAlgorithm    String
  publicUrl             String?
  badgeUrl              String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  company               TrustCompany                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product               TrustProduct?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  registryCase          TrustRegistryCase?             @relation(fields: [registryCaseId], references: [id], onDelete: SetNull)
  registryAsset         TrustRegistryAsset?            @relation(fields: [registryAssetId], references: [id], onDelete: SetNull)
  scanRun               TrustScanRun?                  @relation(fields: [scanRunId], references: [id], onDelete: SetNull)
  statusEvents          TrustCertificateStatusEvent[]
  badge                 TrustBadge?

  @@index([companyId])
  @@index([productId])
  @@index([registryCaseId])
  @@index([registryAssetId])
  @@index([status])
  @@index([expiresAt])
  @@index([riskClass])
  @@index([kyaLevel])
}

model TrustCertificateStatusEvent {
  id              String           @id @default(cuid())
  certificateDbId String
  status          String
  reason          String?
  createdAt       DateTime         @default(now())
  certificate     TrustCertificate @relation(fields: [certificateDbId], references: [id], onDelete: Cascade)

  @@index([certificateDbId, createdAt])
  @@index([status])
}

model TrustBadge {
  id              String           @id @default(cuid())
  certificateDbId String           @unique
  certificateId   String           @unique
  status          String           @default("active")
  svgHash         String?
  lastRenderedAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  certificate     TrustCertificate @relation(fields: [certificateDbId], references: [id], onDelete: Cascade)

  @@index([status])
}

model TrustBillingInvoice {
  id                 String        @id @default(cuid())
  organizationId     String?
  companyId          String?
  registryCaseId     String?
  provider           String        @default("stripe")
  purpose            String
  status             String        @default("draft")
  amountUsdCents     Int
  currency           String        @default("usd")
  lineItemsJson      Json
  customerEmail      String
  stripeCustomerId   String?
  stripeInvoiceId    String?       @unique
  hostedInvoiceUrl   String?
  invoicePdfUrl      String?
  dueAt              DateTime?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  company            TrustCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  registryCase       TrustRegistryCase? @relation(fields: [registryCaseId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([companyId])
  @@index([registryCaseId])
  @@index([purpose])
  @@index([status])
  @@index([customerEmail])
}

model TrustBillingSubscription {
  id                   String        @id @default(cuid())
  organizationId       String?
  companyId            String?
  productId            String?
  provider             String        @default("stripe")
  status               String        @default("pending")
  quantity             Int           @default(1)
  amountUsdCents       Int           @default(1000)
  currency             String        @default("usd")
  customerEmail        String
  stripeCustomerId     String?
  stripeSubscriptionId String?       @unique
  currentPeriodEndsAt  DateTime?
  cancelAtPeriodEnd    Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  company              TrustCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  product              TrustProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([companyId])
  @@index([productId])
  @@index([status])
  @@index([customerEmail])
}

model TrustSurveyInvite {
  id             String        @id @default(cuid())
  organizationId String?
  companyId      String?
  productId      String?
  registryCaseId String?
  email          String
  tokenHash      String        @unique
  surveyType     String        @default("kya_controls")
  status         String        @default("pending")
  expiresAt      DateTime
  submittedAt    DateTime?
  metadataJson   Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  company        TrustCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  product        TrustProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  registryCase   TrustRegistryCase? @relation(fields: [registryCaseId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([companyId])
  @@index([productId])
  @@index([registryCaseId])
  @@index([email])
  @@index([status, expiresAt])
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("owner")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model AppSession {
  id               String       @id @default(cuid())
  sessionTokenHash String       @unique
  userId           String
  organizationId   String
  authProvider     String
  authSubject      String?
  ipHash           String?
  userAgent        String?
  country          String?
  createdAt        DateTime     @default(now())
  lastSeenAt       DateTime     @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  revokedByUserId  String?
  metadataJson     Json?
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([revokedAt])
  @@index([expiresAt])
}

model AuthEvent {
  id             String        @id @default(cuid())
  organizationId String?
  actorUserId    String?
  eventName      String
  authProvider   String?
  authSubject    String?
  email          String?
  ipHash         String?
  userAgent      String?
  country        String?
  success        Boolean       @default(true)
  failureReason  String?
  metadataJson   Json?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation("AuthEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([eventName, createdAt])
  @@index([email, createdAt])
  @@index([success, createdAt])
}

model OrganizationInvitation {
  id              String       @id @default(cuid())
  organizationId  String
  email           String
  role            String       @default("member")
  tokenHash       String       @unique
  status          String       @default("pending")
  invitedByUserId String?
  acceptedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([email, status])
  @@index([expiresAt])
}

model Subscription {
  id                   String       @id @default(cuid())
  organizationId       String
  provider             String       @default("local")
  tier                 String       @default("free")
  status               String       @default("trial")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodEndsAt  DateTime?
  cancelAtPeriodEnd    Boolean      @default(false)
  limitsJson           Json?
  entitlementsJson     Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId])
  @@unique([stripeSubscriptionId])
}

model Project {
  id                String             @id @default(cuid())
  organizationId    String
  name              String
  slug              String
  description       String?
  createdByUserId   String
  archivedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser     User               @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  packages          AgentPackage[]
  deploymentTargets DeploymentTarget[]
  transformJobs     TransformJob[]
  deploymentJobs    DeploymentJob[]

  @@unique([organizationId, slug])
}

model AgentPackage {
  id                    String           @id @default(cuid())
  projectId             String
  name                  String
  slug                  String
  description           String?
  sourcePlatform        String           @default("generic")
  defaultTargetPlatform String?
  latestVersionId       String?
  createdByUserId       String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser         User             @relation("PackageCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  versions              PackageVersion[]
  transformJobs         TransformJob[]

  @@unique([projectId, slug])
}

model PackageVersion {
  id                  String          @id @default(cuid())
  agentPackageId      String
  versionNumber       Int
  status              String          @default("draft")
  origin              String          @default("manual")
  manifestJson        Json
  agentDefinitionJson Json
  compatibilityJson   Json?
  validationJson      Json?
  rawSnapshotPrefix   String?
  createdByUserId     String
  createdAt           DateTime        @default(now())
  agentPackage        AgentPackage    @relation(fields: [agentPackageId], references: [id], onDelete: Cascade)
  createdByUser       User            @relation("VersionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  files               PackageFile[]
  subagents           Subagent[]
  skillRules          SkillRule[]
  transformJobs       TransformJob[]
  deploymentJobs      DeploymentJob[]

  @@unique([agentPackageId, versionNumber])
}

model PackageFile {
  id               String         @id @default(cuid())
  packageVersionId String
  kind             String
  logicalPath      String
  storageKey       String
  mimeType         String
  sizeBytes        Int
  checksumSha256   String
  sourceFormat     String
  createdAt        DateTime       @default(now())
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)

  @@unique([packageVersionId, kind, logicalPath])
}

model Subagent {
  id               String         @id @default(cuid())
  packageVersionId String
  name             String
  slug             String
  description      String
  instructionsMd   String
  toolsJson        Json?
  modelHint        String?
  permissionMode   String?
  metadataJson     Json?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)

  @@unique([packageVersionId, slug])
}

model SkillRule {
  id               String         @id @default(cuid())
  packageVersionId String
  name             String
  kind             String
  bodyMd           String
  metadataJson     Json?
  createdAt        DateTime       @default(now())
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
}

model Credential {
  id              String                @id @default(cuid())
  organizationId  String
  name            String
  provider        String
  kind            String
  ciphertext      String
  keyVersion      String
  metadataJson    Json?
  lastVerifiedAt  DateTime?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser   User                  @relation("CredentialCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  accessLogs      CredentialAccessLog[]
  integrations    Integration[]

  @@unique([organizationId, name])
}

model CredentialAccessLog {
  id           String     @id @default(cuid())
  credentialId String
  actorUserId  String?
  action       String
  jobId        String?
  createdAt    DateTime   @default(now())
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  actorUser    User?      @relation("CredentialAccessActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}

model Integration {
  id             String       @id @default(cuid())
  organizationId String
  provider       String
  status         String       @default("pending")
  credentialId   String?
  configJson     Json?
  lastVerifiedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credential     Credential?  @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider])
}

model DeploymentTarget {
  id              String          @id @default(cuid())
  projectId       String
  name            String
  platform        String
  deliveryMode    String
  configJson      Json?
  isDefault       Boolean         @default(false)
  createdByUserId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser   User            @relation("TargetCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  deploymentJobs  DeploymentJob[]

  @@unique([projectId, name])
}

model TransformJob {
  id               String          @id @default(cuid())
  organizationId   String
  projectId        String?
  agentPackageId   String?
  packageVersionId String?
  jobType          String
  status           String          @default("queued")
  sourcePlatform   String?
  targetPlatform   String?
  inputJson        Json?
  resultJson       Json?
  errorJson        Json?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdByUserId  String
  createdAt        DateTime        @default(now())
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agentPackage     AgentPackage?   @relation(fields: [agentPackageId], references: [id], onDelete: SetNull)
  packageVersion   PackageVersion? @relation(fields: [packageVersionId], references: [id], onDelete: SetNull)
  createdByUser    User            @relation("TransformJobCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
}

model DeploymentJob {
  id                 String           @id @default(cuid())
  organizationId     String
  projectId          String
  packageVersionId   String
  deploymentTargetId String
  status             String           @default("queued")
  triggerSource      String           @default("ui")
  gitRef             String?
  outputJson         Json?
  errorJson          Json?
  startedAt          DateTime?
  finishedAt         DateTime?
  createdByUserId    String
  createdAt          DateTime         @default(now())
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  packageVersion     PackageVersion   @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  deploymentTarget   DeploymentTarget @relation(fields: [deploymentTargetId], references: [id], onDelete: Cascade)
  createdByUser      User             @relation("DeploymentJobCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
}

model AuditEvent {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  entityType     String
  entityId       String
  action         String
  metadataJson   Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}

model ExtensionUsageEvent {
  id                    String       @id @default(cuid())
  organizationId        String
  actorUserId           String?
  eventName             String
  sessionId             String?
  workspaceHash         String?
  phaseId               String?
  phaseTitle            String?
  agentId               String?
  skillLogicalPath      String?
  actionType            String?
  launchStatus          String?
  reasonCode            String?
  promptEstimatedTokens Int?
  promptKind            String?
  promptPreview         String?
  promptText            String?
  promptHash            String?
  promptCaptured        Boolean      @default(false)
  promptCaptureMode     String?
  metadataJson          Json?
  createdAt             DateTime     @default(now())
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser             User?        @relation("ExtensionUsageActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, eventName, createdAt])
  @@index([organizationId, agentId])
  @@index([organizationId, skillLogicalPath])
  @@index([organizationId, promptHash])
}

model ExtensionAuthRequest {
  id             String        @id @default(cuid())
  code           String        @unique
  organizationId String?
  userId         String?
  editor         String
  status         String        @default("pending")
  expiresAt      DateTime
  approvedAt     DateTime?
  deniedAt       DateTime?
  exchangedAt    DateTime?
  pollTokenHash  String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
}

model AgentToken {
  id                   String              @id @default(cuid())
  externalId           String              @unique
  organizationId       String?
  createdByUserId      String?
  name                 String
  sourceClient         String              @default("unknown")
  tokenPrefix          String
  tokenHash            String              @unique
  status               String              @default("trial")
  plan                 String              @default("agent_trial")
  scopesJson           Json
  balanceCredits       Int                 @default(3)
  freeCreditsUsed      Int                 @default(0)
  paidCreditsPurchased Int                 @default(0)
  registrationIpHash   String?
  expiresAt            DateTime?
  lastUsedAt           DateTime?
  revokedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  organization         Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser        User?               @relation("AgentTokenCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  preflightRuns        AgentPreflightRun[]

  @@index([organizationId, status])
  @@index([status, expiresAt])
  @@index([registrationIpHash, createdAt])
}

model AgentPreflightRun {
  id                      String        @id @default(cuid())
  agentTokenId            String
  organizationId          String?
  status                  String        @default("created")
  tier                    String
  sourceClient            String        @default("unknown")
  targetAgent             String?
  taskPreview             String
  taskHash                String
  title                   String
  creditsDebited          Int
  estimatedOriginalTokens Int
  estimatedHandoffTokens  Int
  planJson                Json
  handoffJson             Json
  assuranceJson           Json?
  createdAt               DateTime      @default(now())
  agentToken              AgentToken    @relation(fields: [agentTokenId], references: [id], onDelete: Cascade)
  organization            Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([agentTokenId, createdAt])
  @@index([organizationId, createdAt])
  @@index([taskHash])
}

model GuardScan {
  id                    String            @id @default(cuid())
  organizationId        String
  actorUserId           String
  sourceClient          String            @default("vscode")
  workspaceHash         String?
  score                 Int
  rank                  String
  consentMode           String            @default("local")
  uploadedArtifactCount Int               @default(0)
  scannedAt             DateTime
  createdAt             DateTime          @default(now())
  summaryJson           Json
  categoryScoresJson    Json
  findingsJson          Json
  connectionMapJson     Json?
  extensionsJson        Json?
  mcpServersJson        Json?
  workspaceSurfaceJson  Json?
  packageManagersJson   Json?
  packageScriptsJson    Json?
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser             User              @relation("GuardScanActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  artifacts             GuardArtifact[]
  watchEvents           GuardWatchEvent[]
  baselines             GuardBaseline[]
  cloudAnalysisJobs     CloudAnalysisJob[]

  @@index([organizationId, createdAt])
  @@index([organizationId, workspaceHash, createdAt])
  @@index([organizationId, score])
}

model GuardArtifact {
  id             String       @id @default(cuid())
  guardScanId    String
  organizationId String
  actorUserId    String
  kind           String
  logicalPath    String
  contentHash    String
  redacted       Boolean      @default(true)
  storageKey     String
  mimeType       String
  sizeBytes      Int
  checksumSha256 String
  createdAt      DateTime     @default(now())
  guardScan      GuardScan    @relation(fields: [guardScanId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User         @relation("GuardArtifactActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([guardScanId])
  @@index([organizationId, createdAt])
  @@index([organizationId, logicalPath])
  @@index([contentHash])
}

model GuardBaseline {
  id              String       @id @default(cuid())
  organizationId  String
  workspaceHash   String       @default("default")
  guardScanId     String
  createdByUserId String
  metadataJson    Json?
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  guardScan       GuardScan    @relation(fields: [guardScanId], references: [id], onDelete: Cascade)
  createdByUser   User         @relation("GuardBaselineCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, workspaceHash])
  @@index([organizationId, createdAt])
  @@index([guardScanId])
}

model TeamPolicy {
  id                     String       @id @default(cuid())
  organizationId         String
  mcpAllowlistJson       Json?
  mcpDenylistJson        Json?
  extensionAllowlistJson Json?
  extensionDenylistJson  Json?
  uploadPolicyJson       Json?
  redactionPolicyJson    Json?
  retentionDays          Int          @default(90)
  baselineComparisonJson Json?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId])
}

model CloudAnalysisJob {
  id                  String       @id @default(cuid())
  organizationId      String
  actorUserId         String
  guardScanId         String?
  status              String       @default("queued")
  approvedPayloadJson Json
  resultJson          Json?
  errorMessage        String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser           User         @relation("CloudAnalysisJobActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  guardScan           GuardScan?   @relation(fields: [guardScanId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([guardScanId])
  @@index([status, createdAt])
}

model GuardWatchEvent {
  id             String        @id @default(cuid())
  organizationId String
  actorUserId    String?
  guardScanId    String?
  workspaceHash  String?
  eventType      String
  severity       String
  logicalPath    String
  previousHash   String?
  currentHash    String?
  metadataJson   Json?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?         @relation("GuardWatchEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  guardScan      GuardScan?    @relation(fields: [guardScanId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, workspaceHash, createdAt])
  @@index([organizationId, eventType, createdAt])
}
