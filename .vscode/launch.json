{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Xupra VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/xupra-drylake-vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/extensions/xupra-drylake-vscode/dist/**/*.js"
      ],
      "preLaunchTask": "xupra-extension: build"
    }
  ]
}
