# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/extensions/*/node_modules
/extensions/*/dist
*.vsix
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local app data
/dev.db
/dev.db-journal
/storage/
/prisma/schema.runtime.prisma
/.tmp-smoke/
/.tmp-start.log
/.next-dev-*.log
/.next-start*.log
/.next-start*.pid
