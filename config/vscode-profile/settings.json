  "terminal.integrated.mouseWheelZoom": true,
  "editor.mouseWheelZoom": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell 7",
  "accessibility.verbosity.terminal": false,
  "python.createEnvironment.trigger": "off",
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop"
  ],
  "amazonQ.suppressPrompts": {
    "amazonQChatDisclaimer": true,
    "codeWhispererConnectionExpired": true
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell 7": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
    },
    "PowerShell": {
      "path": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash",
      "icon": "terminal-git-bash"
    },
    "Ubuntu (WSL)": {
      "path": "C:\\WINDOWS\\System32\\wsl.exe",
      "args": [
        "-d",
        "Ubuntu"
      ]
    }
  },
  "traycer.agentMode": "Multi Agent",
  "traycer.enableAutoAnalysis": false,
  "traycer.additionalAgents": [
    "Codex Extension",
    "Codex Extension"
  ],
  "window.newWindowProfile": "Default",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "amazonQ.showCodeWithReferences": false,
  "claudeCode.preferredLocation": "panel",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "zenMode.fullScreen": false,
  "window.newWindowDimensions": "maximized",
  "workbench.statusBar.visible": false,
  "chat.agent.maxRequests": 100,
  "traycer.alwaysAllowPayToRun": true,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "chat.tools.terminal.autoApprove": {
    "ssh": true
  },
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  "traycer.outputLevel": "trace",
