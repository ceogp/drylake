    "vscode-kubernetes.minikube-path-windows": "C:\\Users\\gp\\.vs-kubernetes\\tools\\minikube\\windows-amd64\\minikube.exe"
  },
  "chat.viewSessions.orientation": "stacked",
  "chat.checkpoints.showFileChanges": true,
  "workbench.startupEditor": "none",
  "xupra.baseUrl": "https://drylake.xupracorp.com",
  "xupra.autoScanOnOpen": true,
  "xupra.pullGeneratedFilesAfterExport": true,
  "chat.tools.urls.autoApprove": {
    "https://code.visualstudio.com": true,
    "https://github.com/microsoft/vscode/wiki/*": true,
    "https://marketplace.visualstudio.com": {
      "approveRequest": false,
      "approveResponse": true
    }
  },
  "terminal.integrated.fontSize": 11,
  "settingsSync.ignoredExtensions": []
